@page "{id:int}"
@model SmartShopLite.Pages.Products.DetailsModel
@{
    ViewData["Title"] = "Product Details";
}

<h1>@Model.Product?.Name</h1>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

@if (Model.Product is null)
{
    <div class="alert alert-warning">Product not found.</div>
}
else
{
    <div class="row">
        <div class="col-md-5">
            <img class="img-fluid rounded" src="@Model.Product.ImageUrl" alt="@Model.Product.Name" />
        </div>
        <div class="col-md-7">
            <h2 class="mt-3">@Model.Product.Name</h2>
            <p class="lead">@Model.Product.Description</p>
            <p class="h4 text-primary">@Model.Product.Price.ToString("C")</p>
            <form method="post" class="mb-3">
                <input type="hidden" name="productId" value="@Model.Product.Id" />
                <button type="submit" class="btn btn-success me-2">Add to cart</button>
                <a class="btn btn-outline-secondary" asp-page="Index">Back to products</a>
            </form>
        </div>
    </div>
}
