@page
@model SmartShopLite.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Products";
}

<h1 class="mb-4">Products</h1>

<form method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="q" class="form-control" placeholder="Search products..." value="@Model.SearchQuery" />
        <button class="btn btn-outline-secondary" type="submit">Search</button>
    </div>
</form>

<div class="row">
    @foreach (var product in Model.Products)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <img class="card-img-top" src="@product.ImageUrl" alt="@product.Name" />
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@product.Name</h5>
                    <p class="card-text text-truncate">@product.Description</p>
                    <p class="card-text fw-bold">@product.Price.ToString("C")</p>
                    <a class="btn btn-primary mt-auto" asp-page="Details" asp-route-id="@product.Id">View details</a>
                </div>
            </div>
        </div>
    }
</div>
