@page
@model SmartShopLite.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Products";
}

<h1 class="mb-4">Products</h1>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<form method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="q" class="form-control" placeholder="Search products..." value="@Model.SearchQuery" />
        <button class="btn btn-outline-secondary" type="submit">Search</button>
    </div>
</form>

<div class="row">
    @foreach (var product in Model.Products)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <img class="card-img-top" src="@product.ImageUrl" alt="@product.Name" />
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@product.Name</h5>
                    <p class="card-text text-truncate">@product.Description</p>
                    <p class="card-text fw-bold">@product.Price.ToString("C")</p>
                    <div class="d-flex gap-2 mt-auto">
                        <a class="btn btn-primary" asp-page="Details" asp-route-id="@product.Id">View details</a>
                        <form method="post" class="m-0">
                            <input type="hidden" name="productId" value="@product.Id" />
                            <button type="submit" class="btn btn-outline-success">Add to cart</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
